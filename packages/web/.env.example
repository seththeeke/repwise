# Copy to .env.local and fill in. Never commit .env.local.
# Restart the dev server after changing.

# Cognito (from CDK stack output)
# VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXX
# VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# API: use your API Gateway URL to hit the deployed backend (not localhost).
# Get from CDK stack output, e.g. ApiGatewayUrl or similar.
# VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
