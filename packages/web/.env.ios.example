# Copy to .env.ios or .env.production when building for iOS.
# Values must match the deployed backend (see DEPLOYMENT.md / CDK stack outputs).
# Run: pnpm build (uses production mode) then pnpm cap:sync

# Cognito (from CDK stack output)
# VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXX
# VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# API: API Gateway URL from CDK stack output ApiUrl
# VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# AI workout generation (SSE): Lambda Function URL from CDK output AiWorkoutStreamUrl
# VITE_AI_WORKOUT_STREAM_URL=https://xxxxxxxxxx.lambda-url.us-east-1.on.aws/
